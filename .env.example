# ─────────────────────────────────────────────
# ReviewFlow AI — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Supabase / Neon / any PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/reviewflow?sslmode=require"

# ── Clerk Auth ────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect paths (do not change)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── WhatsApp Provider ─────────────────────────
# Set WHATSAPP_PROVIDER to one of: wati | twilio | none
WHATSAPP_PROVIDER="wati"

# WATI (https://app.wati.io)
WATI_API_URL="https://live-server-XXXXX.wati.io"
WATI_API_TOKEN="your-wati-api-token"

# Twilio (alternative)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ── OpenAI ───────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ── Cron Security ────────────────────────────
# Random secret for protecting cron endpoints
CRON_SECRET="your-random-secret-string"

# ── Super Admin ───────────────────────────────
# Clerk user IDs that have super-admin access
SUPER_ADMIN_IDS="user_xxxx,user_yyyy"
